    "# Slide by slide gene expression compariosn"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "\n",
    "dir_notebook = \"../notebook\"\n",
    "name_dir = \"circa-SD\"\n",
    "run_to_analyze = 'circa4'\n",
    "\n",
    "df = pd.read_parquet(f'{dir_notebook}/csv/{name_dir}/{run_to_analyze}_norm_combined.parquet')\n",
    "\n",
    "Slide_dict = {\n",
    "    'ZT01': 'Light', 'ZT05': 'Light', 'ZT09': 'Light',\n",
    "    'ZT13': 'Dark', 'ZT17': 'Dark', 'ZT21': 'Dark'\n",
    "}\n",
    "\n",
    "df['Slide'] = df['ZT'].map(Slide_dict)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df.groupby('ZT')['Gfap'].mean()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from module.misc import genes_list\n",
    "\n",
    "marker_genes = genes_list('panel_5k') ### Extract all genes. If you want a selected list, use genes_list() (module.misc)\n",
    "\n",
    "grouped_means = df.groupby(['Slide'])[marker_genes].mean()\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "### Count number of genes higher in slide 2 (probably unefficient...)\n",
    "a=0\n",
    "for gene in range(len(grouped_means.columns)):\n",
    "    if grouped_means.iloc[0,gene] < grouped_means.iloc[1,gene]:\n",
    "        a+=1\n",
    "print(a)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "grouped_means = grouped_means.T\n",
    "grouped_means['Diff'] = grouped_means['Dark'] - grouped_means['Light']\n",
    "plt.scatter(x=range(len(grouped_means)), y=grouped_means['Diff'].sort_values())\n",
    "plt.hlines(y=0, xmin = 0, xmax=5007, colors='black')\n",
    "plt.vlines(x=5006/2, ymin=-0.15, ymax=0.15, colors='black')\n",
    "plt.title(f'{run_to_analyze}: Slide 1 vs Slide 2 Gene expression average')"
   ]
  },
